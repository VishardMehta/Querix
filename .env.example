# ── LLM Provider ─────────────────────────────────────────────────────────────
# Option 1 (recommended): OpenRouter — multi-model, free tier available
# Comma-separated list for automatic key rotation
OPENROUTER_API_KEYS="or-key-1,or-key-2,or-key-3"

# Option 2 (fallback): Groq — used only if OPENROUTER_API_KEYS is not set
GROQ_API_KEY=gsk_your_groq_key_here

# ── Per-agent model overrides (optional — defaults shown) ─────────────────────
MODEL_SCHEMA_ANALYST=qwen/qwen3-coder:free
MODEL_ROUTER=meta-llama/llama-3.3-70b:free
MODEL_SQL_GENERATOR=qwen/qwen3-coder:free
MODEL_ANSWER_WRITER=nvidia/nemotron-super-49b:free
MODEL_CHART_AGENT=meta-llama/llama-3.3-70b:free
MODEL_RESULT_VERIFIER=qwen/qwen3-coder:free
MODEL_FALLBACK=meta-llama/llama-3.3-70b:free

# ── Supabase / Production Database ───────────────────────────────────────────
# Create a Supabase project, run supabase/schema.sql in the SQL editor, then
# provide these values from Project Settings -> API / Database.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres
